{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "crons": [
    {
      "path": "/api/cron/leads",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/leads?task=digest",
      "schedule": "0 8 * * *"
    }
  ]
}
